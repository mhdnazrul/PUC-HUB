# ============================================================
# PUC HUB — Backend Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to Git.
# ============================================================

# --- App ---
NODE_ENV=development
PORT=3000

# --- Database (Supabase PostgreSQL) ---
# Get this from: Supabase Dashboard → Settings → Database → Connection String (URI)
DATABASE_URL=postgresql://postgres:[YOUR_PASSWORD]@db.[YOUR_PROJECT_REF].supabase.co:5432/postgres

# --- JWT Authentication ---
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET_AT_LEAST_64_CHARS

# --- Google OAuth2 ---
# Get from: https://console.cloud.google.com → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
# Must match your Google Cloud Console → Authorized Redirect URIs
GOOGLE_REDIRECT_URI=http://localhost:3000/api/v1/auth/google/callback

# --- Frontend (CORS) ---
# Local: http://localhost:5500 | Production: https://puc-hub.vercel.app
FRONTEND_URL=http://localhost:5500

# --- Redis Cache (Optional) ---
# If not set, the app falls back to direct DB queries.
# Get from: Upstash Redis or Redis Cloud
# REDIS_URL=redis://default:YOUR_PASSWORD@YOUR_REDIS_HOST:6379

# --- Sentry Observability (Optional) ---
# Get DSN from: https://sentry.io → Your Project → Settings → Client Keys
# SENTRY_DSN=https://YOUR_KEY@o123456.ingest.sentry.io/YOUR_PROJECT_ID

# --- Logging ---
LOG_LEVEL=info

# --- Admin Seed Script (used by: node scripts/seed-admin.js) ---
ADMIN_STUDENT_ID=0222310005101070
ADMIN_EMAIL=admin@puc.edu.bd
ADMIN_PASSWORD=CHANGE_ME_IMMEDIATELY
