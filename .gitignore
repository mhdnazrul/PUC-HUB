# ============================================================
# PUC HUB — Root .gitignore
# ============================================================

# --- Environment Variables & Secrets (NEVER commit these) ---
.env
.env.local
.env.production
.env.staging
backend/.env
backend/.env.local
backend/.env.production
*.pem
*.key
*.cert

# --- Node / NPM ---
node_modules/
backend/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm

# --- Build & Cache ---
dist/
build/
.cache/
.parcel-cache/

# --- Logs ---
logs/
*.log

# --- OS & Editor ---
.DS_Store
Thumbs.db
.vscode/settings.json
.idea/
*.swp
*.swo

# --- Test Coverage ---
coverage/
.nyc_output/

# --- Vercel ---
.vercel/

# --- Misc ---
*.local
